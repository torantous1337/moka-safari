---
export interface Props {
  title: string;
  description: string;
  price: number;
  currency: string;
  duration: string;
  image: string;
  whatsappNumber: string;
  rating: number;
  reviewCount: number;
  badge: string;
}

const { title, description, price, currency, duration, image, whatsappNumber, rating, reviewCount, badge } = Astro.props;

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
const imageSrc = `${baseUrl}/${image.replace(/^\/+/, '')}`;
const whatsappMessage = encodeURIComponent(`Hi! I'm interested in booking the "${title}" tour ($${price} ${currency}, ${duration}). Could you please share more details?`);
const whatsappLink = `https://wa.me/${whatsappNumber}?text=${whatsappMessage}`;

const filledStars = Math.round(rating);
---

<div class="group relative bg-white rounded-2xl shadow-lg overflow-hidden flex flex-col transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl">
  <!-- Badge Ribbon -->
  {badge && (
    <div class="absolute top-3 right-3 z-10 bg-gradient-to-r from-teal-500 to-emerald-500 text-white text-xs font-bold px-3 py-1 rounded-full shadow-lg">
      {badge}
    </div>
  )}

  <!-- Image with zoom on group hover -->
  <div class="relative overflow-hidden">
    <img
      src={imageSrc}
      alt={title}
      class="w-full h-56 object-cover transition-transform duration-500 group-hover:scale-110"
      loading="lazy"
    />
    <!-- Frosted glass duration overlay on image -->
    <div class="absolute bottom-3 left-3 backdrop-blur-md bg-white/30 text-white text-xs font-semibold px-3 py-1.5 rounded-full border border-white/20 shadow">
      ⏱ {duration}
    </div>
  </div>

  <div class="p-5 flex flex-col flex-grow">
    <h3 class="text-lg font-bold text-slate-900 mb-1">{title}</h3>

    <!-- Star Ratings -->
    <div class="flex items-center gap-1.5 mb-3">
      <div class="flex items-center">
        {Array.from({ length: 5 }).map((_, i) => (
          <svg
            class={`w-4 h-4 ${i < filledStars ? 'text-amber-400' : 'text-gray-300'}`}
            fill="currentColor"
            viewBox="0 0 20 20"
            aria-hidden="true"
          >
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
        ))}
      </div>
      <span class="text-sm font-semibold text-slate-700">{rating}</span>
      <span class="text-xs text-slate-400">({reviewCount} reviews)</span>
    </div>

    <p class="text-slate-500 text-sm leading-relaxed mb-4 flex-grow">{description}</p>

    <div class="flex items-center justify-between mt-auto pt-3 border-t border-slate-100">
      <div>
        <span class="text-2xl font-extrabold text-teal-600">${price}</span>
        <span class="text-xs font-normal text-slate-400 ml-1">{currency}</span>
      </div>
      <a
        href={whatsappLink}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-gradient-to-r from-teal-500 to-emerald-500 hover:from-teal-600 hover:to-emerald-600 text-white font-semibold px-5 py-2.5 rounded-xl transition-all duration-300 shadow-md hover:shadow-lg"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Book Now
      </a>
    </div>
  </div>
</div>
