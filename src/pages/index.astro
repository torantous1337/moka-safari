---
import TourCard from '../components/TourCard.astro';
import tours from '../data/tours.json';

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
const whatsappFabLink = `https://wa.me/201282718183?text=${encodeURIComponent('Hi! I would like to enquire about your Hurghada tours.')}`;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${baseUrl}/favicon.svg`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content="Discover the best adventure tours in Hurghada, Egypt. Snorkeling, desert safaris, dolphin trips and more. Book via WhatsApp!" />
    <title>Hurghada Adventure Tours</title>
    <style>
      @keyframes bob {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(10px); }
      }
      @keyframes pulse-ring {
        0% { transform: scale(1); opacity: 0.6; }
        100% { transform: scale(1.5); opacity: 0; }
      }
      .animate-bob {
        animation: bob 2s ease-in-out infinite;
      }
      .fab-pulse::before {
        content: '';
        position: absolute;
        inset: 0;
        border-radius: 9999px;
        background: #25D366;
        animation: pulse-ring 1.5s ease-out infinite;
        z-index: -1;
      }
    </style>
  </head>
  <body class="bg-amber-50 text-slate-900 min-h-screen">
    <!-- Sticky Glassmorphic Header -->
    <nav class="sticky top-0 z-50 backdrop-blur-lg bg-slate-900/80 border-b border-white/10 shadow-lg">
      <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
        <a href="#" class="text-xl font-extrabold text-white tracking-tight">
          🌊 Moka Safari
        </a>
        <a
          href="#tours"
          class="inline-block bg-gradient-to-r from-teal-400 to-emerald-400 text-slate-900 font-bold px-5 py-2 rounded-xl text-sm hover:from-teal-300 hover:to-emerald-300 transition-all duration-300 shadow-md"
        >
          Enquire Now
        </a>
      </div>
    </nav>

    <!-- Hero Section -->
    <header class="relative min-h-[85vh] flex items-center justify-center overflow-hidden bg-slate-900">
      <!-- Background gradient overlay simulating a dark overlay on an image -->
      <div class="absolute inset-0 bg-gradient-to-br from-slate-900 via-slate-800 to-teal-900 opacity-90"></div>
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-teal-500/20 via-transparent to-transparent"></div>

      <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
        <p class="text-teal-400 font-semibold text-sm tracking-widest uppercase mb-4">Premium Red Sea Experiences</p>
        <h1 class="text-5xl sm:text-6xl md:text-7xl font-extrabold tracking-tight text-white mb-6 leading-tight">
          Hurghada<br/>
          <span class="bg-gradient-to-r from-teal-400 to-emerald-300 bg-clip-text text-transparent">Adventure Tours</span>
        </h1>
        <p class="text-lg sm:text-xl text-slate-300 max-w-2xl mx-auto mb-10">
          Explore the Red Sea's finest experiences — from vibrant coral reefs to golden desert dunes.
          Book instantly via WhatsApp.
        </p>
        <a
          href="#tours"
          class="inline-block bg-gradient-to-r from-teal-500 to-emerald-500 text-white font-bold px-10 py-4 rounded-2xl shadow-xl hover:shadow-2xl hover:from-teal-400 hover:to-emerald-400 transition-all duration-300 text-lg mb-12"
        >
          Explore Tours
        </a>
        <!-- Bobbing scroll-down arrow -->
        <div class="animate-bob">
          <a href="#tours" class="inline-block text-teal-400 hover:text-teal-300 transition-colors" aria-label="Scroll to tours">
            <svg class="w-8 h-8 mx-auto" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
            </svg>
          </a>
        </div>
      </div>
    </header>

    <!-- Tours Section -->
    <main id="tours" class="max-w-6xl mx-auto px-4 py-20">
      <div class="text-center mb-14">
        <p class="text-teal-600 font-semibold text-sm tracking-widest uppercase mb-2">Handpicked For You</p>
        <h2 class="text-4xl font-extrabold text-slate-900">Our Curated Tours</h2>
      </div>
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {tours.map((tour) => (
          <TourCard
            title={tour.title}
            description={tour.description}
            price={tour.price}
            currency={tour.currency}
            duration={tour.duration}
            image={tour.image}
            whatsappNumber={tour.whatsappNumber}
            rating={tour.rating}
            reviewCount={tour.reviewCount}
            badge={tour.badge}
          />
        ))}
      </div>
    </main>

    <!-- Footer -->
    <footer class="bg-slate-900 text-slate-400 text-center py-10 border-t border-slate-800">
      <p class="text-sm">
        &copy; {new Date().getFullYear()} Moka Safari — Hurghada Adventure Tours. All rights reserved.
      </p>
    </footer>

    <!-- Floating WhatsApp FAB -->
    <a
      href={whatsappFabLink}
      target="_blank"
      rel="noopener noreferrer"
      class="fab-pulse fixed bottom-6 right-6 z-50 w-14 h-14 bg-[#25D366] rounded-full flex items-center justify-center shadow-xl hover:shadow-2xl hover:scale-110 transition-all duration-300"
      aria-label="Chat on WhatsApp"
    >
      <svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
    </a>
  </body>
</html>
