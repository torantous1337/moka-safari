---
import TourCard from '../components/TourCard.astro';
import tours from '../data/tours.json';

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${baseUrl}/favicon.svg`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content="Discover the best adventure tours in Hurghada, Egypt. Snorkeling, desert safaris, dolphin trips and more. Book via WhatsApp!" />
    <title>Hurghada Adventure Tours</title>
  </head>
  <body class="bg-gray-50 text-gray-900 min-h-screen">
    <!-- Hero Section -->
    <header class="relative bg-gradient-to-br from-emerald-600 to-teal-700 text-white">
      <div class="max-w-6xl mx-auto px-4 py-20 sm:py-28 text-center">
        <h1 class="text-4xl sm:text-5xl md:text-6xl font-extrabold tracking-tight mb-4">
          Hurghada Adventure Tours
        </h1>
        <p class="text-lg sm:text-xl text-emerald-100 max-w-2xl mx-auto mb-8">
          Explore the Red Sea's finest experiences — from vibrant coral reefs to golden desert dunes.
          Book instantly via WhatsApp.
        </p>
        <a
          href="#tours"
          class="inline-block bg-white text-emerald-700 font-bold px-8 py-3 rounded-xl shadow-lg hover:shadow-xl hover:bg-emerald-50 transition-all"
        >
          View Tours ↓
        </a>
      </div>
    </header>

    <!-- Tours Section -->
    <main id="tours" class="max-w-6xl mx-auto px-4 py-16">
      <h2 class="text-3xl font-bold text-center mb-12">Our Curated Tours</h2>
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {tours.map((tour) => (
          <TourCard
            title={tour.title}
            description={tour.description}
            price={tour.price}
            currency={tour.currency}
            duration={tour.duration}
            image={tour.image}
            whatsappNumber={tour.whatsappNumber}
          />
        ))}
      </div>
    </main>

    <!-- Footer -->
    <footer class="bg-gray-900 text-gray-400 text-center py-8">
      <p class="text-sm">
        &copy; {new Date().getFullYear()} Hurghada Adventure Tours. All rights reserved.
      </p>
    </footer>
  </body>
</html>
